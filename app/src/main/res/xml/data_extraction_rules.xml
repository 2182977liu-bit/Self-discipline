<?xml version="1.0" encoding="utf-8"?>
<!--
    数据提取规则 (Android 12+)
    定义云端备份和设备间传输时排除的数据
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="user_preferences.xml"/>
        <exclude domain="database" path="time_manager.db"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="user_preferences.xml"/>
        <exclude domain="database" path="time_manager.db"/>
    </device-transfer>
</data-extraction-rules>
